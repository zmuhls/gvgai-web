{
  "name": "gvgai-web-frontend",
  "version": "1.0.0",
  "description": "Web frontend for GVGAI with OpenRouter LLM integration",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "node --test test/*.test.js",
    "java:prepare": "node scripts/prepare-java-runtime.js",
    "telemetry:check": "node scripts/check-supabase-telemetry.js",
    "telemetry:backfill": "node scripts/backfill-telemetry.js",
    "eval:arcade": "node scripts/run-arcade-eval.js --dry-run --all",
    "eval:arcade:execute": "node scripts/run-arcade-eval.js"
  },
  "dependencies": {
    "chokidar": "^3.5.3",
    "csv-parser": "^3.0.0",
    "dotenv": "^17.2.3",
    "express": "^4.18.2",
    "socket.io": "^4.6.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.11"
  }
}
