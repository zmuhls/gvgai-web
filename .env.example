# Ollama Cloud API key for the stated cloud model roster
OLLAMA_API_KEY=

# OpenRouter API key for provider fallback when vLLM or Ollama Cloud fails
# Get yours at: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# vLLM routes fall back to this Ollama Cloud model before OpenRouter
LEGION_FALLBACK_MODEL=gemma3:27b

# Supabase telemetry storage
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_TELEMETRY_TABLE=telemetry_events
TELEMETRY_ENABLED=true
TELEMETRY_BATCH_SIZE=25
TELEMETRY_FLUSH_MS=3000
TELEMETRY_FALLBACK_MODE=on-error
TELEMETRY_STORE_PROMPTS=false
